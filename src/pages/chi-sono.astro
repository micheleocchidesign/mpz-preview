---
import BaseLayout from "../layouts/BaseLayout.astro";
import WavyDivider from "../components/WavyDivider.astro";
import SpacerIcon from "../components/SpacerIcon.astro";
import BookCallBanner from "../components/BookCallBanner.astro";
import QuoteSeed from '../components/QuoteSeed.astro';
import { Image } from 'astro:assets';
import heroImage from "../img/marta-zola-chi-sono.jpg";
import bioImage from "../img/marta-zola-bio.jpg";
import immagineAltare from "../img/altare.jpg";
import { object } from "astro:schema";
const base = import.meta.env.BASE_URL;
// Array strutturato per la formazione
const formazione = [
  {
    title: "Formazione in corso di coaching dell’Anima - coaching evolutivo",
    subtitle: "Luna scuola di coaching per l’Anima",
    description: "Certificazione Professionale accreditata come formazione di Livello 1 e 2 da parte della Federazione Internazionale di Coaching (ICF). LUNA è una Scuola di Coaching, ha un approccio integrato e trasformativo che considera la persona nella sua interezza: mente, corpo, anima; e accoglie la complessità dell’esperienza umana. È un approccio trauma-informed, somatico, evolutivo ed anche spirituale e al contempo profondamente ancorato alla vita concreta, quotidiana, reale.",
    date: "2025 / 2027",
    highlight: true // Per dare un leggero accento visivo al corso attuale
  },
  {
    title: "Formazione completa Insegnanti Yoga - Hatha Yoga",
    subtitle: "Diploma della Scuola LIBERA SCUOLA DI HATHA YOGA HAMSA. Certificazione CONI tramite CSAIn - WEPA",
    description: "Il corso insegnanti è strutturato in 7 moduli in funzione del sistema dei 7 Chakra evolutivi - con esercizi specifici e mirati per ogni livello, Asana, Pranayama, Mudra, Bandha, tecniche di visualizzazione, rilassamento e meditazione - e segue la metodologia del Pranayoga Method® di Maurizio Morelli. 300 ore di formazione",
    date: "2023 / 2024"
  },
  {
    title: "Diploma in Naturopatia con specializzazione in Fitocomplementi",
    subtitle: "SIMO - Scuola Italiana di Medicina Olistica e di Naturopatia",
    description: "1600 ore di formazione, di cui 270 in fitocomplementi. Riflessologia plantare (ad oggi con contratto di co-docenza). Cromopuntura secondo la Medicina tradizionale cinese con stage aggiuntivo di 60 ore.",
    date: "2016 / 2021"
  },
  {
    title: "Diploma operatrice olistica benessere femminile e attestato facilitatrice in costellazioni familiari sistemiche secondo Bert Hellinger",
    subtitle: "La scuola del Sacro Femminile, oggi Benessere Femminile, affiliata all'associazione Fenoop.",
    description: "Diploma operatrice olistica 250 ore ECP 157. Attestato facilitatrice costellazioni familiari 750 ore ECP 142",
    date: "2021 / 2025"
  },
  {
    title: "Corso SHRI DEVI YOGA I e II - Lo yoga del sacro femminile",
    subtitle: "Presso RAMA YOGA con certificazione YOGA ALLIANCE ITALIA. Insegnante Lila Devi Marialaura Bonfanti.",
    description: "Lo Shri Devi Yoga è un percorso che affonda le sue radici nello Shaktismo e nel Tantrismo Non Duale, incentrato sul culto del divino femminile. E’ una pratica di riconnessione con il proprio corpo e la natura.  Asana, mudra e kriya si incontrano per una pratica completa. 160 ore di formazione certificate YOGA ALLIANCE ITALIA insegnante Lila Devi Marialaura Bonfanti",
    date: "2021"
  },
  {
    title: "Corso YOGA NIDRA - Lo yoga del sonno",
    subtitle: "Presso RAMA YOGA con certificazione YOGA ALLIANCE ITALIA. Insegnante Lila Devi Marialaura Bonfanti.",
    description: "o Yoga Nidra è una pratica accessibile a tutti ed è particolarmente adatta nei momenti in cui si ha bisogno di recuperare energia e calma. Non richiede niente, se non lo stare sdraiati sul tappetino mentre si viene guidati con la voce. 60 ore di formazione certificate",
    date: "2022"
  },
  {
    title: "Corso intensivo Riflessologia Plantare Zu",
    subtitle: "Zu Center",
    description: "Centro Specialistico per lo Studio e l’Applicazione della Reflessologia del Piede è stato il primo centro in Italia a operare ufficialmente. Corso intensivo e aggiornamento Professionale Riflessologia Plantare Zu riservato agli operatori delle Discipline Bionaturali. Identificazione Aree Riflesse Sensibili, tecniche di massaggio,morfologia psicosomatica riflessa e diagnostica morfologica. 150 ore",
    date: "2019/2020"
  },
  {
    title: "Corso 1°anno operatore professionale di tuina",
    subtitle: "IOME - Istituto Orientale di Medicina Energetica",
    description: "Corso con 12 ore di ANATOMIA, 24 ore di MEDICINA TRADIZIONALE CINESE, 60 ore di PRATICA GUIDATA MASSAGGIO TRADIZIONALE CINESE TUINA. Il massaggio tradizionale cinese TUINA è una delle Discipline Bio Naturali (D.B.N.) riconosciute dal Comitato Tecnico Scientifico di Regione Lombardia.",
    date: "2018/2019"
  }
];
const pageTitle = "Chi sono | Marta Zola";
const pageDescription = "Accompagno le donne a sentire le proprie radici, riscoprire i propri ritmi e sentirsi a casa nel corpo e nelle emozioni, attraverso un approccio integrato.";
---

<BaseLayout 
  title={pageTitle} 
  description={pageDescription} 
>
    <!-- HERO SECTION -->
    <section class="about-hero">
        <div class="hero-container">
            <div class="hero-content">
                <span class="section-overline"
                    >Naturopatia integrata per il benessere femminile</span
                >
                <h1 class="hero-title">
                    Accompagno le donne a sentire le proprie radici,
                </h1>
                <div class="hero-description">
                    <p>
                        <b>riscoprire i propri ritmi e sentirsi a casa nel corpo e
                        nelle emozioni,</b> attraverso un approccio integrato.
                    </p>
                </div>
            </div>
            <div class="hero-image">
                <div class="portrait-wrapper">
                    <Image
                            src={heroImage}
                            alt="Marta Zola - Naturopatia integrata e benessere femminile"
                            loading="eager"
                            format="webp"
                            quality="high"
                        />
                </div>
            </div>
        </div>
        <WavyDivider position="bottom" color="var(--bg-light)" />
    </section>

    <!-- APPROCCIO SECTION -->
    <section class="approach-section">
        <div class="container-narrow">
            <h2 class="section-title text-center">Il mio approccio</h2>
            <p>
                <strong>Unisco naturopatia, coaching, tecniche corporee e uno sguardo
                sistemico ispirato alle costellazioni familiari,</strong> per offrire un
                approccio a tutto tondo sulla persona. Mi piace guardare oltre
                le corazze, avere fiducia nel cambiamento e andare oltre ciò che
                appare, per portare ordine e chiarezza dopo il caos.
            </p>
            <p>
                <i
                    >Molti percorsi olistici, infatti, ti invitano subito a
                    “lasciar andare”,</i> ma se stai arrivando dal dolore e dalla sfiducia, può sembrare
                impossibile: <strong>prima hai bisogno di fare ordine nei tuoi blocchi o
                difficoltà fisiche ed emozionali. Iniziamo da lì.</strong>
            </p>
            <p class="tools-paragraph">
                Partendo dalla naturopatia e il coaching uso strumenti
                differenti online e in presenza -
                <span class="tool-accent">riflessologia plantare</span>,
                <span class="tool-accent">massaggi</span>,
                <span class="tool-accent">embodiment</span>,
                <span class="tool-accent">somatica</span>,
                <span class="tool-accent">costellazioni familiari</span> - e li integro
                in modo flessibile: li adatto a te e al cambiamento che desideri,
                scegliendo ciò che può sostenerti meglio nella tua esperienza interiore
                e nel corpo. <strong>Non seguo un'unica via: trovo quella che può aiutarti</strong>
                a sentirti a casa e più radicata in te stessa.
            </p>
            <p>
                Ci tengo a darti <strong>strumenti pratici,</strong> non solo comprensione
                e supporto: <strong>osservazioni su abitudini, energia e ciclo mestruale,
                piccoli esercizi da fare a casa, pratiche corporee, rilassamento,
                rimedi naturali.</strong> Il mio approccio è profondo e radicato nella vita
                di tutti i giorni. Ti accompagno in modo graduale attraverso il cambiamento:
                perché se sei arrivata al limite è anche un’opportunità per rimettere
                radici in te stessa, non avere paura del tempo, trovare un equilibrio.
                Per trovare una condizione di benessere, nel modo più naturale possibile,
                attraverso una visione olistica dell’essere umano, che mira a promuovere
                il benessere attraverso metodi naturali e l’interconnessione di mente
                e corpo, stimolando la capacità innata dell’organismo di ritrovare
                l’equilibrio.
            </p>
            <QuoteSeed 
                quote="Marta sa creare un vero contatto; il lavoro fatto insieme mi ha aiutata a ritrovare la stabilità e la forza per la mia strada." 
                author="Valeria V." 
                link={true}
            />
            <p>
                Osservo la <strong
                    >connessione tra corpo, mente, emozioni e storia familiare,</strong
                > perché spesso i nodi che ci portiamo non sono solo nostri, ma eredità
                che si ripetono da generazioni. Ti accompagno a ritrovare il contatto
                con il corpo, abitandolo per davvero. A sentire le emozioni, non
                come macigni, ma come opportunità, così da attraversarle con coraggio
                e aprirti alla morbidezza. A osservare i sintomi del corpo, i pensieri
                limitanti e gli schemi radicati che non ti permettono di andare avanti.
                Finché sono lì, è come se viaggiassi con il pilota automatico, anche
                nelle abitudini di vita e nelle piccole scelte di ogni giorno.
            </p>
            <p>
                Quando si crea questa <strong>connessione autentica,</strong> tutto
                si allinea:
                <strong>qualcosa dentro si muove, si apre, respira.</strong> Lì ti
                accorgerai che siamo nel posto giusto, che spesso non è reale solo
                ciò che è misurabile.
            </p>
            <p>
                <strong>Il mio metodo è profondo e concreto:</strong> facciamo chiarezza
                nei pensieri, troviamo nuovi gesti, rimedi e pratiche che puoi portare
                nella tua vita di tutti i giorni. Credo che il <strong
                    >cambiamento</strong
                > sia possibile solo se veramente <strong
                    >radicato in ciò che desideri: per questo lavoro sulla continuità, sulla pratica, sull'ascolto
                e sulla connessione tra la mente e il corpo.</strong
                > L’obiettivo delle mie
                sessioni è accompagnarti a trovare un senso di sicurezza, fare luce
                su una situazione che stai vivendo. Ascoltarsi è l’unico modo per
                smettere di delegare il proprio benessere e prendersi la propria
                responsabilità, per questo ti accompagno nell’esplorazione delle
                risposte più efficaci.
            </p>
            <p>
                <strong>Ogni donna ha in sé la capacità di ritrovarsi, quando finalmente
                si sente vista, sostenuta e accompagnata senza giudizio.</strong>
            </p>

            <SpacerIcon margin="4rem auto" width="600px" />

            <h2 class="section-title text-center">Qualcosa su di me</h2>
            <p><strong>Sono schietta e sincera, ma anche profondamente accogliente.</strong></p>
            <p>
                Energica, curiosa, testarda. Amo i tempi lenti, cucinare (come
                atto di cura e di piacere), viaggiare, avere persone a casa per
                pranzi e cene che durano ore. Amo l'ordine, ma ho bisogno di
                caos creativo. Faccio mille cose, ma poi cerco riposo e tempi
                introspettivi.
            </p>
            <p>
                Oggi sono anche, e soprattutto, una mamma orsa: ho imparato
                quanto la forza possa essere dolcezza, quanto stare nella
                vulnerabilità sia un atto di coraggio.
            </p>
        </div>
    </section>

    <!-- CHI SONO (BIO ESTESA) SECTION -->
    <section class="bio-extended-section" id="chi-sono-completo">
        <WavyDivider position="top" color="var(--bg-light)" />
        <div class="container">
            <h2 class="section-title chiaro">Chi sono</h2>
            <div class="bio-extended-grid">
                <div class="bio-extended-text">
                    <p>
                        <strong
                            >Sarda da generazioni, sud americana di adozione,
                            vivo a Milano.</strong
                        >
                    </p>

                    <p>
                        Fin da ragazza ho avuto una naturale curiosità per tutto
                        ciò che riguarda il <strong>benessere</strong>: il cibo,
                        la cosmesi naturale, le erbe e gli olii essenziali.
                        Negli anni dell’università, mentre frequentavo
                        Sociologia nella facoltà di Scienze Politiche, ho
                        incontrato per la prima volta anche <strong>lo yoga, le piante e
                        gli oli essenziali.</strong> Un mondo che stava iniziando a
                        mandarmi un messaggio:
                        <strong>rallenta e respira</strong>. Osserva come ti
                        stai muovendo, tra ideologie, politica e lotte per
                        l’emancipazione femminile.
                    </p>

                    <p>
                        <strong>Nel 2016 ho intrapreso la Scuola di Naturopatia SIMO,
                        traducendo in competenze le mie passioni.</strong> Per anni ho
                        cercato il mio posto nel mondo: studi, corsi,
                        esperienze, trasformazioni interiori e passi indietro.
                        Ho lavorato nella Cooperazione Internazionale come
                        project manager, mentre continuavo ad approfondire nuovi
                        strumenti.
                    </p>

                    <p>
                        Mi sono avvicinata al <strong>femminile sacro</strong>,
                        ai cerchi di donne e alle <strong>costellazioni familiari</strong>, sentendo che lì c’era una parte profonda della mia
                        missione:
                        <strong
                            >accompagnare me e le donne nel loro ritorno a sé</strong>. Ho studiato ancora e mi sono specializzata in Shri
                        Devi Yoga, lo yoga del femminile, una pratica che
                        sostiene il corpo della donna nei suoi cambiamenti,
                        rispettando la
                        <strong>ciclicità naturale</strong> e favorendo l’ascolto profondo.
                        Inoltre la formazione in <strong>Yoga Nidra (lo yoga del sonno)</strong> mi ha fatto comprendere 
                        quanto si possa <strong>portare pace con la parola</strong>. 
                    </p>
                    <p>
                        <strong>Ho sentito sulla mia pelle che non potevo cambiare la
                        mia vita rimanendo nello stesso paradigma produttivo che
                        volevo abbandonare.</strong> 
                        
                      </p>
                    <p>  
                        Quando ho lasciato il mio lavoro
                        nella Cooperazione Internazionale, l’ho fatto con
                        immensa gratitudine per ciò che è stato: oggi racchiudo
                        tutta la mia esperienza — i viaggi, i progetti, lo
                        studio — nel mio lavoro, che ha come cornice la naturopatia e 
                        il coaching per il benessere femminile.
                    </p>

                    <p>
                        Accompagno le donne che desiderano cambiare la propria
                        vita a trovare una maggiore <strong
                            >consapevolezza fisica ed emotiva</strong
                        >: sentirsi davvero, aprirsi alla morbidezza,
                        attraversare il proprio dolore con coraggio.
                    </p>
                </div>
                <div class="bio-extended-image">
                    <div class="bio-portrait-large">
                        <Image
                            src={bioImage}
                            alt="Marta Zola"
                        />
                    </div>
                </div>
            </div>

            <div class="bio-extended-full">
                <p class="bio-final">
                    Il mio compito è camminare accanto, con delicata fermezza,
                    affinché ognuna possa riconoscere la propria verità e
                    ritrovare radici nella propria vita.
                </p>
            </div>
        </div>
        <WavyDivider position="bottom" color="var(--bg-light)" />
    </section>

    <!-- FORMAZIONE -->
    <section class="education-section">
        <div class="container container-narrow">
            <div class="education-intro text-center">
                <span class="section-overline">Radici e Competenze</span>
                <h2 class="section-title">Il mio percorso formativo</h2>
                <p class="education-lead">
                    Il mio lavoro nasce da un percorso fatto di ricerca, esperienza e trasformazione personale.
La mia formazione in Sociologia sotto Scienze Politiche e un passato come project manager nel sanitario nella Cooperazione Internazionale hanno arricchito il mio sguardo sulla persona e sui sistemi, e non posso che esserne grata. 
Integro naturopatia, coaching, tecniche corporee e yoga con uno sguardo sistemico ispirato alle costellazioni familiari; continuo a formarmi per offrire uno spazio sempre più profondo a me e alle persone che incontro.

                </p>
            </div>

            <div class="education-timeline">
                {formazione.map((item) => (
                    <div class={`education-item ${item.highlight ? 'is-current' : ''}`}>
                        <div class="education-meta">
                            <span class="education-date">{item.date}</span>
                            {item.highlight && <span class="current-badge">In corso</span>}
                        </div>
                        <div class="education-card">
                            <h3>{item.title}</h3>
                            <h4>{item.subtitle}</h4>
                            {item.description && <p>{item.description}</p>}
                        </div>
                    </div>
                ))}
            </div>
        </div>
    </section>

    <!-- COSA MI GUIDA SECTION -->
    <section class="values-section">
        <div class="container">
            <h2 class="section-title text-center">Cosa mi guida</h2>

            <div class="values-grid">
                <!-- Libertà -->
                <div class="value-card">
                    <h3>Libertà</h3>
                    <p>
                        Voglio vivere con fluidità, seguendo i miei ritmi, in un
                        tempo che non sia costrittivo. Accompagno le donne a
                        riconquistare la stessa libertà: quella di ascoltarsi e
                        di ritornare a se stesse.
                    </p>
                </div>

                <!-- Coerenza -->
                <div class="value-card">
                    <h3>Coerenza</h3>
                    <p>
                        Non potrei accompagnare altre persone verso un benessere
                        che io stessa non pratico: coerenza per me è fare quello
                        che dico, vivere quello che insegno, anche quando è
                        difficile.
                    </p>
                </div>

                <!-- Cura -->
                <div class="value-card">
                    <h3>Cura</h3>
                    <p>
                        Cura per me stessa e per chi si affida a me, per le
                        relazioni, per gli spazi che creo. La cura è attenzione,
                        presenza, responsabilità.
                    </p>
                </div>

                <!-- Equità -->
                <div class="value-card">
                    <h3>Equità</h3>
                    <p>
                        Credo nel cerchio, nella condivisione, in un tempo
                        nutriente per tutte e tutti.
                    </p>
                </div>

                <!-- Integrità -->
                <div class="value-card">
                    <h3>Integrità</h3>
                    <p>
                        Portare tutte le parti di me, quella pratica e quella
                        spirituale, quella organizzata e quella istintiva,
                        quella forte e quella vulnerabile, senza doverle
                        nascondere.
                    </p>
                </div>
            </div>
        </div>
        <div class="values-manifesto container">
            <div class="manifesto-content">
                <p>
                    Abbiamo bisogno di tempi che rispettano i nostri <strong>ritmi naturali</strong>: 
                    la società che abbiamo costruito è sempre meno umana.
                    Riconoscere ciò che per noi non va bene è già una possibilità di cambiamento, 
                    di evoluzione: cerco di guardare le cose in una prospettiva antica e futura, ciclica.
                </p>
            </div>
        </div>
    </section>
    <BookCallBanner 
        title="Vuoi conoscermi meglio? Prenota uno spazio di ascolto conoscitivo gratuito di 30 minuti." 
        buttonText="PRENOTA ORA" 
        buttonLink="/call-conoscitiva"
        showBottomDivider={false}
        imgParallax={immagineAltare}
        overlayColor="var(--text-dark)"
    />
</BaseLayout>

<style>

    /* HERO */
    .about-hero {
        background-color: var(--accent-1-bg);
        padding: 10rem 0 8rem;
        position: relative;
    }

    .hero-container {
        display: grid;
        grid-template-columns: 2fr 1fr;
        gap: 4rem;
        align-items: center;
        max-width: var(--container-width);
        margin: 0 auto;
        padding: 0 1.5rem;
    }

    .portrait-wrapper {
        width: 100%;
        max-width: 450px; /* Limita la grandezza massima */
        margin: 0 auto;
        /* Definisce il rapporto 4:5 direttamente */
        aspect-ratio: 4 / 5; 
        border-radius: 300px 300px 4px 4px;
        border: solid 2px var(--brand-gold);
        box-shadow: 0 30px 60px rgba(0, 0, 0, 0.1);
        overflow: hidden;
    }

    .portrait-wrapper img {
        width: 100%;
        height: 100%;
        /* Fondamentale: l'immagine riempie il contenitore senza deformarsi */
        object-fit: cover; 
        display: block;
    }

    /* APPROACH */
    .approach-section {
        padding: 1rem 0;
        background-color: var(--bg-light);
    }

    .approach-section,
    .bio-extended-text p {
        font-family: var(--font-body);
        /*font-size: 1.125rem;*/
        line-height: 1.8;
        color: var(--text-dark);
        margin-bottom: 1.2rem;
    }

    .tool-accent {
        color: var(--brand-primary); /* Usiamo il tuo oro dai token */
        font-weight: 800;
        position: relative;
        display: inline-block;
        white-space: nowrap;
    }

    .citazione {
        display: inline-block;
        color: var(--brand-primary);
        font-size: 2.2rem;
        line-height: 1.2;
        font-family: var(--font-headings);
        padding: 1.2rem 0;
    }

    /* BIO EXTENDED */
    .bio-extended-section {
        padding: 6rem 0;
        position: relative;
        background-color: var(--accent-2); /* Cambiamo bg per dare stacco */
        color: var(--bg-light);
    }

    .bio-extended-grid {
        display: grid;
        grid-template-columns: 2fr 1fr;
        gap: 6rem;
        /*align-items: center;*/
        margin: 1rem 0;
    }

    .bio-portrait-large {
        border-radius: 300px 300px 4px 4px;
        overflow: hidden;
        box-shadow: 0 40px 80px rgba(0, 0, 0, 0.2);
        border: solid 2px var(--brand-gold);
        will-change: transform;
    }

    .bio-final {
        font-family: var(--font-headings);
        font-size: 2.2rem;
        color: var(--accent-4);
        text-align: center;
        margin: 5rem !important;
        line-height: 1.4;
    }

    /* RESPONSIVE */
    @media (max-width: 1024px) {
        .hero-container,
        .bio-grid,
        .approach-grid,
        .bio-extended-grid,
        .personal-grid {
            grid-template-columns: 1fr;
            text-align: center;
        }
        .hero-intro-text,
        .hero-content,
        .bio-extended-text,
        .personal-text-block {
            margin: 0 auto;
        }
        .hero-image,
        .bio-extended-image {
            max-width: 500px;
            margin: 3rem auto 0;
        }
        .personal-quote-block {
            border-left: none;
            border-top: 4px solid var(--brand-gold);
        }
    }
    /* --- EDUCATION SECTION --- */
    .education-section {
        padding: 6rem 1.5rem;
        background-color: var(--bg-light);
    }

    .education-intro {
        max-width: 750px;
        margin: 0 auto 4rem;
    }

    .education-lead {
        font-size: 1.1rem;
        line-height: 1.8;
        color: var(--text-dark);
        margin-top: 1.5rem;
    }

    .education-timeline {
        max-width: 800px;
        margin: 0 auto;
        position: relative;
        padding-left: 2rem;
        border-left: 2px solid var(--accent-3); /* La linea verticale dell'albero */
    }

    .education-item {
        position: relative;
        margin-bottom: 3rem;
    }

    .education-item:last-child {
        margin-bottom: 0;
    }

    /* Il "punto/seme" sulla linea temporale */
    .education-item::before {
        content: "";
        position: absolute;
        left: calc(-2rem - 7px);
