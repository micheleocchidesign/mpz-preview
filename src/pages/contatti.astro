---
import BaseLayout from "../layouts/BaseLayout.astro";
import WavyDivider from "../components/WavyDivider.astro";
const base = import.meta.env.BASE_URL;
---

<BaseLayout 
    title="Contatti | Marta Zola" 
    description="Inizia il tuo percorso di benessere. Scrivimi per informazioni o per prenotare una consulenza."
>
    <main class="contact-page">
        <section class="contact-hero">
            <div class="container container-narrow">
                <span class="section-overline">Contatti</span>
                <h1 class="hero-title">Possiamo iniziare da qui...</h1>
                <p class="hero-description">
                    Scegli la modalità più comoda per te: scrivimi un messaggio o prenota direttamente la tua call gratuita.
                </p>
            </div>
            <WavyDivider position="bottom" color="var(--bg-lighter)" />
        </section>

        <section class="contact-grid-section">
            <div class="container">
                <div class="contact-main-grid">
                    
                    <div class="form-col">
                        <div class="contact-card">
                            <h2 class="card-title">Inviami un messaggio</h2>
                            <p class="card-subtitle">Scrivimi attraverso questo form per richiedere informazioni o acquistare un servizio.</p>
                            
                            <form
    name="contact"
    method="POST"
    data-netlify="true"
    action="/successo" 
    class="contact-form"
>
    <input type="hidden" name="form-name" value="contact" />
    <input 
        type="hidden" 
        name="subject" 
        data-remove-prefix 
        value="Nuovo messaggi dal sito per: %{reason}" 
    />

    <div class="form-group">
        <label for="name">Nome e Cognome</label>
        <input
            type="text"
            id="name"
            name="name"
            required
            placeholder="Inserisci il tuo nome"
        />
    </div>

    <div class="form-group">
        <label for="email">Email</label>
        <input
            type="email"
            id="email"
            name="email"
            required
            placeholder="latua@email.it"
        />
    </div>

    <div class="form-group">
        <label for="reason">Di cosa hai bisogno?</label>
        <select id="reason" name="reason" required>
            <option value="" disabled selected>Seleziona un'opzione</option>
            <option value="Percorso Radici">Percorso "Radici"</option>
            <option value="La Prima Semina">Incontro singolo "La prima semina"</option>
            <option value="Chiamata Conoscitiva">Chiamata conoscitiva gratuita</option>
            <option value="Altre Informazioni">Altre informazioni</option>
        </select>
    </div>

    <div class="form-group">
        <label for="message">Messaggio</label>
        <textarea
            id="message"
            name="message"
            rows="5"
            required
            placeholder="Come posso aiutarti?"></textarea>
    </div>

    <div class="form-group checkbox-group">
        <label class="checkbox-container">
            <input type="checkbox" name="privacy-consent" required />
            <span class="privacy-text">
                Accetto la <a href={base + "privacy-policy"}>Privacy Policy</a> e il trattamento dei dati personali.
            </span>
        </label>
    </div>

    <button type="submit" class="btn-primary">Invia Messaggio</button>
</form>
                        </div>
                    </div>

                    <div class="calendar-col">
                        <div class="contact-card gold-border promo-card">
                            <div class="promo-content">
                                <h2 class="card-title">Prenota la tua Call</h2>
                                <p class="card-subtitle">
                                    Se vuoi prenotare il mio <strong>Spazio di Ascolto Conoscitivo</strong>, ti aspetto per una chiacchierata gratuita di 30 minuti.
                                </p>
                                <p class="promo-text">
                                    Cliccando il tasto qui sotto verrai indirizzato alla pagina di prenotazione dove potrai scegliere il giorno e l'ora che preferisci.
                                </p>
                                
                                <a href="https://calendly.com/martazola-info/30min" target="_blank" rel="noopener noreferrer" class="btn-primary btn-gold">
                                    Vedi disponibilità
                                </a>

                                <div class="info-footer">
                                    <p>Vuoi saperne di più sulla call? <a href="/call-conoscitiva" class="text-link">Clicca qui.</a></p>
                                </div>
                            </div>
                        </div>
                    </div>

                </div>
            </div>
        </section>
    </main>
</BaseLayout>

<style>
    .contact-page { background-color: var(--bg-lighter); }

    /* HERO */
    .contact-hero {
        background-color: var(--accent-1-bg);
        padding: 10rem 0 5rem;
        text-align: center;
        position: relative;
    }

    .hero-description {
        max-width: 700px;
        margin: 0 auto;
        line-height: 1.6;
    }
    .text-link {
        color: var(--brand-primary);
        text-decoration: none;
        border-bottom: 1px solid var(--brand-gold);
        transition: all 0.3s ease;
        padding-bottom: 1px;
    }

    .text-link:hover {
        color: var(--brand-gold);
        border-bottom-color: var(--brand-primary);
    }
    /* GRID LAYOUT */
    .contact-main-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 3rem;
        padding: 4rem 0 8rem;
        align-items: start;
    }

    .contact-card {
        background: white;
        padding: 2.5rem;
        border-radius: 15px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.03);
    }

    .gold-border { border: 1px solid var(--brand-gold); }

    .card-title {
        font-family: var(--font-headings);
        color: var(--brand-primary);
        margin-bottom: 0.5rem;
        font-size: 1.8rem;
    }

    .card-subtitle {
        font-size: 0.95rem;
        margin-bottom: 2rem;
        opacity: 0.9;
        line-height: 1.5;
    }

    /* FORM STYLING */
    .contact-form { display: flex; flex-direction: column; gap: 1.5rem; }

    .form-group { display: flex; flex-direction: column; gap: 0.5rem; }

    .form-group label {
        font-weight: 600;
        font-size: 14px;
        color: var(--brand-primary);
    }

    .form-group input, .form-group textarea, .form-group select {
        padding: 1rem;
        border: 1px solid rgba(0, 0, 0, 0.1);
        border-radius: 4px;
        font-family: var(--font-body);
        background-color: var(--bg-lighter);
        outline: none;
        transition: border-color 0.3s ease;
    }

    .form-group input:focus, .form-group textarea:focus, .form-group select:focus {
        border-color: var(--brand-gold);
    }

    /* Checkbox */
    .checkbox-group { margin-top: 0.5rem; }

    .checkbox-container {
        display: flex;
        gap: 0.8rem;
        cursor: pointer;
        font-size: 0.9rem;
        line-height: 1.4;
    }

    .privacy-text a {
        color: var(--brand-primary);
        text-decoration: underline;
        font-weight: 600;
    }

    /* RESPONSIVE */
    @media (max-width: 1024px) {
        .contact-main-grid {
            grid-template-columns: 1fr;
            gap: 2rem;
        }
        .contact-hero { padding: 8rem 1.5rem 4rem; }
    }
</style>