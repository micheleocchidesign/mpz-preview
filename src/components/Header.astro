---
const base = import.meta.env.BASE_URL;
---

<header class="site-header">
    <div class="header-container">
        <div class="logo">
            <a href={base}><img src={base + "/MPZ_logo_horiz_fullcolor.svg"} alt="Logo" /></a>
        </div>
        <button class="menu-toggle" aria-label="Apri menu">
            <span class="bar"></span>
            <span class="bar"></span>
            <span class="bar"></span>
        </button>
        <nav class="main-nav">
            <ul>
                <li><a href={base + "/chi-sono"}>Chi Sono</a></li>
                <li class="dropdown">
                    <a href={base + "/servizi"} class="dropdown-trigger">
                        Servizi <span class="arrow"></span>
                    </a>
                    <ul class="dropdown-menu">
                        <li><a href={base + "/servizi/percorso-radici"}>Percorso "Radici"</a></li>
                        <li><a href={base + "/servizi/incontro-la-prima-semina"}>Incontro "La Prima Semina"</a></li>
                    </ul>
                </li>
                <li><a href={base + "/contatti"}>Contatti</a></li>
                <li><a href={base + "/faq"}>FAQ</a></li>
            </ul>
        </nav>
    </div>
</header>

<style>
    .site-header {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        z-index: 100;
        padding: 1.8rem 0;
        background-color: var(--bg-lighter);
    }

    .header-container {
        max-width: var(--container-width);
        margin: 0 auto;
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 0 1.5rem;
    }

    .logo img{
        height: 50px;
    }

    .main-nav ul {
        display: flex;
        gap: 2.5rem;
        list-style: none;
        margin: 0;
        padding: 0;
    }

    .main-nav a {
        text-decoration: none;
        color: var(--text-dark);
        font-family: var(--font-body);
        font-weight: 500;
        font-size: 0.938rem;
        transition: color 0.3s ease;
    }

    .main-nav a:hover {
        color: var(--brand-primary);
    }

    /* --- Dropdown Desktop --- */
    .dropdown {
        position: relative;
    }

    .dropdown-menu {
        position: absolute;
        top: 100%;
        left: 0;
        background-color: var(--bg-lighter);
        min-width: 220px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.05);
        opacity: 0;
        visibility: hidden;
        transform: translateY(10px);
        transition: all 0.3s ease;
        padding: 1rem 0 !important;
        border-radius: 4px;
        display: block !important; /* Sovrascrive il flex del nav */
    }

    .dropdown:hover .dropdown-menu {
        opacity: 1;
        visibility: visible;
        transform: translateY(0);
    }

    .dropdown-menu li {
        margin-bottom: 0 !important;
    }

    .dropdown-menu a {
        padding: 0.7rem 1.5rem;
        display: block;
        font-size: 0.875rem;
    }

    .arrow {
        display: inline-block;
        width: 8px;
        height: 8px;
        border-right: 1.5px solid currentColor;
        border-bottom: 1.5px solid currentColor;
        transform: rotate(45deg);
        margin-left: 5px;
        margin-bottom: 3px;
        transition: transform 0.3s;
    }

    .menu-toggle {
        display: none;
        flex-direction: column;
        gap: 6px;
        background: none;
        border: none;
        cursor: pointer;
        padding: 10px;
        z-index: 1000;
    }

    .bar {
        width: 30px;
        height: 2px;
        background-color: var(--brand-primary);
        transition: 0.3s;
    }

    @media (max-width: 768px) {
        .logo img{
            height: 35px;
        }
        .menu-toggle {
            display: flex;
        }

        .main-nav {
            position: fixed;
            top: 0;
            right: -100%; /* Nascosto a destra */
            width: 80%; /* Occupa l'80% della larghezza */
            height: 100vh;
            background-color: var(--bg-lighter);
            box-shadow: -10px 0 30px rgba(0,0,0,0.1);
            transition: 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
            padding-top: 100px;
            z-index: 999;
        }

        .main-nav.active {
            right: 0; /* Entra in scena */
        }

        .main-nav ul {
            flex-direction: column;
            align-items: center;
            gap: 2rem;
        }

        .main-nav a {
            font-size: 1.2rem;
        }

        .dropdown-menu {
            position: static;
            opacity: 1;
            visibility: visible;
            transform: none;
            box-shadow: none;
            padding: 0.5rem 0 0 1rem !important;
            display: none !important; /* Lo mostriamo solo se la classe è attiva */
            background: transparent;
        }

        .dropdown.open .dropdown-menu {
            display: block !important;
        }

        .dropdown.open .arrow {
            transform: rotate(-135deg);
            margin-bottom: -2px;
        }

        /* Animazione Hamburger a "X" quando attivo */
        .menu-toggle.active .bar:nth-child(1) {
            transform: translateY(8px) rotate(45deg);
        }
        .menu-toggle.active .bar:nth-child(2) {
            opacity: 0;
        }
        .menu-toggle.active .bar:nth-child(3) {
            transform: translateY(-8px) rotate(-45deg);
        }
    }
</style>
<script>
    const menuToggle = document.querySelector('.menu-toggle');
    const mainNav = document.querySelector('.main-nav');
    const dropdownTrigger = document.querySelector('.dropdown-trigger');
    const dropdown = document.querySelector('.dropdown');

    // Toggle menu principale
    menuToggle.addEventListener('click', () => {
        mainNav.classList.toggle('active');
        menuToggle.classList.toggle('active');
    });

    // Gestione dropdown su mobile
    dropdownTrigger.addEventListener('click', (e) => {
        if (window.innerWidth <= 768) {
            e.preventDefault(); // Impedisce di andare subito alla pagina servizi
            dropdown.classList.toggle('open');
        }
    });
</script>