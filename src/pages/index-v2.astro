---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Marta Paola Zola | Naturopata Olistica">
    <main class="home-main">
        <!-- HERO SECTION (Updated from index.astro) -->
        <section class="hero">
            <div class="hero-bg">
                <div class="bg-left"></div>
                <div class="bg-right"></div>
            </div>

            <div class="hero-container">
                <div class="col-img">
                    <div class="arch-wrapper">
                        <img
                            src="/mani-hero.jpg"
                            alt="Marta Paola Zola - Naturopatia"
                            class="hero-arch-img"
                        />
                    </div>
                </div>

                <div class="col-text">
                    <div class="text-content">
                        <h1 class="hero-title">
                            Riscopri la tua <br />natura autentica
                        </h1>
                        <p class="hero-description">
                            Accompagno le persone in un percorso di benessere
                            consapevole, attraverso rimedi naturali e un
                            approccio olistico personalizzato per ritrovare
                            equilibrio e vitalità.
                        </p>
                        <div class="hero-actions">
                            <a href="#servizi" class="btn-primary"
                                >I miei servizi</a
                            >
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- CHI SONO SECTION -->
        <section class="about-section" id="chi-sono">
            <div class="about-container">
                <div class="about-image-col">
                    <div class="about-arch-wrapper">
                        <img
                            src="https://plus.unsplash.com/premium_photo-1669740215572-5e49b2d7eee0?q=80&w=627&auto=format&fit=crop"
                            alt="Marta Paola Zola"
                            class="about-img"
                        />
                    </div>
                </div>
                <div class="about-text-col">
                    <span class="section-overline">Chi Sono</span>
                    <h2 class="section-title">
                        Passione per la natura e cura dell'anima
                    </h2>
                    <p class="section-text">
                        Sono Marta Paola Zola, naturopata olistica con anni di
                        esperienza nel guidare le persone verso uno stile di
                        vita più sano e in armonia con i ritmi naturali. Il mio
                        approccio integra diverse discipline per trattare non
                        solo il sintomo, ma la persona nella sua interezza.
                    </p>
                    <a href="/chi-sono" class="btn-secondary"
                        >Scopri la mia storia</a
                    >
                </div>
            </div>
        </section>

        <!-- SERVIZI SECTION -->
        <section class="services-section" id="servizi">
            <div class="services-container">
                <div class="services-header">
                    <span class="section-overline">I Miei Servizi</span>
                    <h2 class="section-title">Percorsi personalizzati</h2>
                </div>
                <div class="services-grid">
                    <a href="/servizi/naturopatia" class="service-card">
                        <div class="service-icon">01</div>
                        <h3 class="service-title">Consulenza Naturopatica</h3>
                        <p class="service-excerpt">
                            Un'analisi approfondita del tuo stato di benessere
                            per definire un piano personalizzato.
                        </p>
                        <span class="service-link">Dettagli →</span>
                    </a>
                    <a href="/servizi/floriterapia" class="service-card">
                        <div class="service-icon">02</div>
                        <h3 class="service-title">Floriterapia</h3>
                        <p class="service-excerpt">
                            L'energia dei fiori per riarmonizzare le emozioni e
                            affrontare blocchi interiori.
                        </p>
                        <span class="service-link">Dettagli →</span>
                    </a>
                    <a href="/servizi/nutrizione" class="service-card">
                        <div class="service-icon">03</div>
                        <h3 class="service-title">Nutrizione Olistica</h3>
                        <p class="service-excerpt">
                            Alimentazione consapevole come fondamento per la
                            salute del corpo e della mente.
                        </p>
                        <span class="service-link">Dettagli →</span>
                    </a>
                </div>
            </div>
        </section>

        <!-- CONTATTI SECTION -->
        <section class="contact-section" id="contatti">
            <div class="contact-container">
                <div class="contact-header">
                    <span class="section-overline">Contatti</span>
                    <h2 class="section-title">Inizia il tuo percorso</h2>
                    <p class="section-text">
                        Scrivimi per informazioni o per prenotare una
                        consulenza. Sarò felice di accompagnarti.
                    </p>
                </div>
                <form
                    name="contact"
                    method="POST"
                    data-netlify="true"
                    class="contact-form"
                >
                    <div class="form-group">
                        <label for="name">Nome e Cognome</label>
                        <input
                            type="text"
                            id="name"
                            name="name"
                            required
                            placeholder="Inserisci il tuo nome"
                        />
                    </div>
                    <div class="form-group">
                        <label for="email">Email</label>
                        <input
                            type="email"
                            id="email"
                            name="email"
                            required
                            placeholder="latua@email.it"
                        />
                    </div>
                    <div class="form-group">
                        <label for="message">Messaggio</label>
                        <textarea
                            id="message"
                            name="message"
                            rows="5"
                            required
                            placeholder="Come posso aiutarti?"></textarea>
                    </div>
                    <button type="submit" class="btn-primary"
                        >Invia Messaggio</button
                    >
                </form>
            </div>
        </section>
    </main>
</BaseLayout>

<style is:global>
    /* --- COMMON / RESET --- */
    .home-main {
        margin: 0 !important;
        padding: 0 !important;
        width: 100% !important;
        overflow-x: hidden;
    }

    section {
        padding: 6rem 1.5rem;
    }

    .section-overline {
        display: block;
        font-family: var(--font-body);
        text-transform: uppercase;
        letter-spacing: 0.2rem;
        font-size: 12px;
        color: var(--brand-gold);
        margin-bottom: 1rem;
        font-weight: 600;
    }

    .section-title {
        font-family: var(--font-headings);
        font-size: clamp(2rem, 4vw, 3rem);
        color: var(--brand-primary);
        margin-bottom: 1.5rem;
        line-height: 1.2;
    }

    .section-text {
        font-family: var(--font-body);
        font-size: 1.125rem;
        line-height: 1.8;
        color: var(--text-dark);
        margin-bottom: 2rem;
    }

    .btn-primary {
        display: inline-block;
        padding: 1.125rem 2.8rem;
        background-color: var(--brand-primary);
        color: white;
        text-decoration: none;
        font-family: var(--font-body);
        border-radius: 4px;
        text-transform: uppercase;
        letter-spacing: 0.2rem;
        transition: transform 0.3s ease, background-color 0.3s ease;
        font-size: 12px;
        border: none;
        cursor: pointer;
    }

    .btn-primary:hover {
        background-color: var(--brand-gold);
        transform: translateY(-2px);
    }

    .btn-secondary {
        display: inline-block;
        padding: 1rem 0;
        color: var(--brand-primary);
        text-decoration: none;
        font-family: var(--font-body);
        font-weight: 600;
        border-bottom: 2px solid var(--brand-gold);
        transition: border-color 0.3s ease;
    }

    .btn-secondary:hover {
        border-color: var(--brand-primary);
    }

    /* --- HERO --- */
    .hero {
        position: relative;
        height: 100vh;
        width: 100%;
        overflow: hidden;
        display: flex;
        align-items: center;
        padding: 0;
    }

    .hero-bg {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        display: grid;
        grid-template-columns: 40% 60%;
        z-index: 1;
    }

    .bg-left {
        background: url("/radici.jpg");
        background-size: cover;
        background-position: center;
    }

    .bg-right {
        background-color: var(--accent-3);
    }

    .hero-container {
        position: relative;
        z-index: 2;
        width: 100%;
        height: 100%;
        display: grid;
        grid-template-columns: 40% 60%;
        padding-top: 80px;
    }

    .col-img {
        display: flex;
        align-items: center;
        justify-content: flex-end;
    }

    .arch-wrapper {
        width: 55%;
        max-width: 500px;
        aspect-ratio: 0.65;
        border-radius: 500px 500px 0 0;
        overflow: hidden;
        transform: translateX(20%);
        box-shadow: 0 30px 60px rgba(0, 0, 0, 0.12);
    }

    .hero-arch-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
    }

    .col-text {
        display: flex;
        align-items: center;
        padding-left: 15%;
        padding-right: 5%;
    }

    .text-content {
        max-width: 500px;
    }

    .hero-title {
        font-family: "Yeseva One", serif;
        font-size: clamp(2.8rem, 5vw, 4.2rem);
        color: var(--brand-primary);
        line-height: 1.1;
        margin-bottom: 2rem;
    }

    .hero-description {
        font-family: var(--font-body);
        font-size: 1.125rem;
        line-height: 1.8;
        margin-bottom: 3rem;
    }

    /* --- ABOUT --- */
    .about-section {
        background-color: var(--bg-light);
    }

    .about-container {
        max-width: var(--container-width);
        margin: 0 auto;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 6rem;
        align-items: center;
    }

    .about-arch-wrapper {
        width: 100%;
        max-width: 450px;
        aspect-ratio: 0.8;
        border-radius: 500px 500px 0 0;
        overflow: hidden;
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.1);
    }

    .about-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .about-text-col {
        max-width: 500px;
    }

    /* --- SERVICES --- */
    .services-section {
        background-color: var(--accent-3);
    }

    .services-container {
        max-width: var(--container-width);
        margin: 0 auto;
    }

    .services-header {
        text-align: center;
        margin-bottom: 4rem;
    }

    .services-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 2rem;
    }

    .service-card {
        background-color: white;
        padding: 3rem 2rem;
        border-radius: 8px;
        text-decoration: none;
        color: inherit;
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        display: flex;
        flex-direction: column;
    }

    .service-card:hover {
        transform: translateY(-10px);
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.05);
    }

    .service-icon {
        font-family: var(--font-headings);
        font-size: 2rem;
        color: var(--brand-gold);
        margin-bottom: 1.5rem;
        opacity: 0.5;
    }

    .service-title {
        font-family: var(--font-headings);
        font-size: 1.5rem;
        color: var(--brand-primary);
        margin-bottom: 1rem;
    }

    .service-excerpt {
        font-family: var(--font-body);
        line-height: 1.6;
        margin-bottom: 2rem;
        flex-grow: 1;
    }

    .service-link {
        font-weight: 600;
        color: var(--brand-gold);
        text-transform: uppercase;
        font-size: 12px;
        letter-spacing: 1px;
    }

    /* --- CONTACT --- */
    .contact-section {
        background-color: var(--bg-light);
    }

    .contact-container {
        max-width: 700px;
        margin: 0 auto;
    }

    .contact-header {
        text-align: center;
        margin-bottom: 4rem;
    }

    .contact-form {
        display: grid;
        gap: 2rem;
    }

    .form-group {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    .form-group label {
        font-weight: 600;
        font-size: 14px;
        color: var(--brand-primary);
    }

    .form-group input,
    .form-group textarea {
        padding: 1rem;
        border: 1px solid rgba(0, 0, 0, 0.1);
        border-radius: 4px;
        font-family: var(--font-body);
        outline: none;
        transition: border-color 0.3s ease;
        background: white;
    }

    .form-group input:focus,
    .form-group textarea:focus {
        border-color: var(--brand-gold);
    }

    /* --- RESPONSIVE --- */
    @media (max-width: 1024px) {
        .hero {
            height: auto;
            min-height: 100vh;
            display: block;
        }

        .hero-bg {
            grid-template-columns: 1fr;
            grid-template-rows: 40% 60%;
        }

        .hero-container {
            grid-template-columns: 1fr;
            padding-bottom: 5rem;
        }

        .col-img {
            justify-content: center;
            height: 50vh;
        }

        .arch-wrapper {
            transform: translateX(0);
            width: 60%;
            margin: 0 auto;
        }

        .col-text {
            padding: 4rem 1.5rem 0;
            text-align: center;
            justify-content: center;
        }

        .about-container {
            grid-template-columns: 1fr;
            gap: 3rem;
            text-align: center;
        }

        .about-arch-wrapper {
            margin: 0 auto;
        }

        .about-text-col {
            margin: 0 auto;
        }

        .services-grid {
            grid-template-columns: 1fr;
        }
    }
</style>
