<style>
  .spacer-container {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.5rem;
    width: 100%;
    margin-left: auto;
    margin-right: auto;
  }

  .line {
    flex-grow: 1;
    height: 1px;
    background-color: var(--brand-gold);
    opacity: 0.3;
  }

  .icon-wrapper {
    width: 40px; /* Leggermente più grande per apprezzare i dettagli */
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .icon-wrapper svg {
    width: 100%;
    height: 100%;
    /* Opzionale: aggiungi un filtro se vuoi un effetto più morbido */
  }
</style>