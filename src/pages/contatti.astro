---
import BaseLayout from "../layouts/BaseLayout.astro";
import WavyDivider from "../components/WavyDivider.astro";
const base = import.meta.env.BASE_URL;
---

<BaseLayout 
    title="Contatti | Marta Zola" 
    description="Inizia il tuo percorso di benessere. Scrivimi per informazioni o per prenotare una consulenza."
>
    <main class="contact-page">
        <section class="contact-hero">
            <div class="container container-narrow">
                <span class="section-overline">Contatti</span>
                <h1 class="hero-title">Possiamo iniziare da qui...</h1>
                <p class="hero-description">
                    Scrivimi attraverso questo form per richiedere informazioni o acquistare un servizio.
                    <br/>Se invece vuoi conoscere il mio <strong>Spazio di Ascolto Conoscitivo</strong>, una call gratuita di 30 minuti, <a href={base + "/call-conoscitiva"} class="text-link">clicca qui.</a></strong>
                </p>
            </div>
            <WavyDivider position="bottom" color="var(--bg-lighter)" />
        </section>

        <section class="form-section">
            <div class="container container-narrow">
                <div class="form-wrapper">
                    <form
                    name="contact"
                    method="POST"
                    data-netlify="true"
                    class="contact-form"
                >
                    <div class="form-group">
                        <label for="name">Nome e Cognome</label>
                        <input
                            type="text"
                            id="name"
                            name="name"
                            required
                            placeholder="Inserisci il tuo nome"
                        />
                    </div>
                    <div class="form-group">
                        <label for="email">Email</label>
                        <input
                            type="email"
                            id="email"
                            name="email"
                            required
                            placeholder="latua@email.it"
                        />
                    </div>
                    <div class="form-group">
                        <label for="reason">Di cosa hai bisogno?</label>
                        <select id="reason" name="reason" required>
                            <option value="" disabled selected>Seleziona un'opzione</option>
                            <option value="percorso-radici">Percorso "Radici"</option>
                            <option value="la-prima-semina">Incontro singolo "La prima semina"</option>
                            <option value="chiamata-conoscitiva">Chiamata conoscitiva gratuita</option>
                            <option value="altro">Altre informazioni</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label for="message">Messaggio</label>
                        <textarea
                            id="message"
                            name="message"
                            rows="5"
                            required
                            placeholder="Come posso aiutarti?"></textarea>
                    </div>
                    <div class="form-group checkbox-group">
                        <label class="checkbox-container">
                            <input type="checkbox" name="privacy" required />
                            <span class="checkmark"></span>
                            <span class="privacy-text">
                                Accetto la <a href="/privacy">Privacy Policy</a> e il trattamento dei dati personali.
                            </span>
                        </label>
                    </div>
                    <button type="submit" class="btn-primary"
                        >Invia Messaggio</button
                    >
                </form>
                </div>
            </div>
        </section>
    </main>
</BaseLayout>

<style>
    .contact-page {
        background-color: var(--bg-lighter);
    }

    /* HERO */
    .contact-hero {
        background-color: var(--accent-1-bg);
        padding: 10rem 0 3rem;
        text-align: center;
        position: relative;
    }

    .text-link {
        color: var(--brand-primary);
        text-decoration: none;
        border-bottom: 1px solid var(--brand-gold);
        transition: all 0.3s ease;
        padding-bottom: 1px;
    }

    .text-link:hover {
        color: var(--brand-gold);
        border-bottom-color: var(--brand-primary);
    }

    /* FORM STYLING */
    .form-section {
        padding: 4rem 0 8rem;
    }

    .contact-form {
        display: grid;
        gap: 2rem;
    }

    .form-group {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    .form-group label {
        font-weight: 600;
        font-size: 14px;
        color: var(--brand-primary);
    }

    .form-group input,
    .form-group textarea {
        padding: 1rem;
        border: 1px solid rgba(0, 0, 0, 0.1);
        border-radius: 4px;
        font-family: var(--font-body);
        outline: none;
        transition: border-color 0.3s ease;
        background: var(--bg-lighter);
    }

    .form-group input:focus,
    .form-group textarea:focus {
        border-color: var(--brand-gold);
    }

    /* Stile specifico per il Select (Dropdown) */
    .form-group select {
        padding: 1rem;
        border: 1px solid rgba(0, 0, 0, 0.1);
        border-radius: 4px;
        font-family: var(--font-body);
        background-color: var(--bg-lighter);
        cursor: pointer;
        outline: none;
    }

    .form-group select:focus {
        border-color: var(--brand-gold);
    }

    /* Checkbox e Privacy */
    .checkbox-group {
        flex-direction: row;
        align-items: flex-start;
        gap: 1rem;
        margin-top: 1rem;
    }

    .checkbox-container {
        display: flex;
        gap: 0.8rem;
        cursor: pointer;
        font-size: 0.9rem;
        line-height: 1.4;
    }

    .checkbox-container input {
        width: 18px;
        height: 18px;
        margin-top: 2px;
        accent-color: var(--brand-primary);
    }

    .privacy-text a {
        color: var(--brand-primary);
        text-decoration: underline;
        font-weight: 600;
    }

    /* RESPONSIVE */
    @media (max-width: 768px) {
        .form-grid {
            grid-template-columns: 1fr;
        }

        .form-wrapper {
            padding: 2rem 1.5rem;
        }

        .contact-hero {
            padding: 8rem 0 4rem;
        }
    }
</style>