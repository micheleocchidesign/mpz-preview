---
interface Props {
    position?: "top" | "bottom";
    color?: string;
}

const { position = "top", color = "var(--bg-light)" } = Astro.props;
---

<div class={`svg-divider mask-${position}`}>
    <svg
        data-name="Layer 1"
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 1200 120"
        preserveAspectRatio="none"
    >
        <path
            d="M321.39,56.44c58-10.79,114.16-30.13,172-41.86,82.39-16.72,168.19-17.73,250.45-.39C823.78,31,906.67,72,985.66,92.83c70.05,18.17,148.84,27.8,216.54,28.9V0H0V27.35A600.21,600.21,0,0,0,321.39,56.44Z"
            style={{ fill: color }}></path>
    </svg>
</div>

<style>
    .svg-divider {
        position: absolute;
        left: 0;
        width: 100%;
        overflow: hidden;
        line-height: 0;
        z-index: 5;
    }

    .mask-top {
        top: 0;
    }

    .mask-bottom {
        bottom: 0;
    }

    .mask-bottom svg {
        transform: rotate(180deg);
    }

    .svg-divider svg {
        position: relative;
        display: block;
        width: calc(100% + 1.3px);
        height: 80px;
    }
</style>
