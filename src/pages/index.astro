---
import BaseLayout from "../layouts/BaseLayout.astro";
import LunarPhases from "../components/LunarPhases.astro";
import WavyDivider from "../components/WavyDivider.astro";
import BookCallBanner from "../components/BookCallBanner.astro";
---

<BaseLayout title="Marta Paola Zola | Naturopata Olistica">
    <main class="home-main">
        <!-- HERO SECTION -->
        <section class="hero">
            <div class="hero-bg">
                <div class="bg-left"></div>
                <div class="bg-right"></div>
            </div>

            <div class="hero-container">
                <div class="col-img">
                    <div class="arch-wrapper">
                        <img
                            src="{${import.meta.env.BASE_URL}/mani-hero.jpg}"
                            alt="Marta Paola Zola - Naturopatia"
                            class="hero-arch-img"
                        />
                    </div>
                </div>

                <div class="col-text">
                    <div class="text-content">
                        <h1 class="hero-title">
                            Respira, cambia il modo in cui stai nella tua vita,
                            rimetti radici in te stessa.
                        </h1>
                        <p class="hero-description">
                            <b
                                >Ciao, sono Marta. Benvenuta in uno spazio
                                protetto.</b
                            ><br />
                            Grazie a un approccio di Naturopatia integrata ti accompagno
                            a sentire le tue radici, per sentirti a casa nel corpo
                            e nelle emozioni.
                        </p>
                        <div class="hero-actions">
                            <a href="#servizi" class="btn-primary"
                                >I miei servizi</a
                            >
                        </div>
                    </div>
                </div>
            </div>
			<!-- SVG Divider between Hero and About -->
        <WavyDivider position="bottom" color="var(--bg-light)" />
        </section>

        <!-- CHI SONO SECTION -->
        <section class="about-section" id="chi-sono">
            <div class="about-container">
                <div class="about-image-col">
                    <div class="about-arch-wrapper">
                        <img
                            src="https://plus.unsplash.com/premium_photo-1669740215572-5e49b2d7eee0?q=80&w=627&auto=format&fit=crop"
                            alt="Marta Paola Zola"
                            class="about-img"
                        />
                    </div>
                </div>
                <div class="about-text-col">
                    <span class="section-overline">Chi Sono</span>
                    <h2 class="section-title">
                        Passione per la natura e cura dell'anima
                    </h2>
                    <p class="section-text">
                        Sono Marta Paola Zola, naturopata olistica con anni di
                        esperienza nel guidare le persone verso uno stile di
                        vita più sano e in armonia con i ritmi naturali. Il mio
                        approccio integra diverse discipline per trattare non
                        solo il sintomo, ma la persona nella sua interezza.
                    </p>
                    <a href="/chi-sono" class="btn-secondary"
                        >Scopri la mia storia</a
                    >
                </div>
            </div>
        </section>

        <!-- CTA SECTION - DISCOVERY CALL -->
        <BookCallBanner bottomDividerColor="var(--accent-1-bg)"/>

        <!-- SERVIZI SECTION -->
        <section class="services-section" id="servizi">
            <div class="services-container">
                <div class="services-header">
                    <span class="section-overline">I Miei Servizi</span>
                    <h2 class="section-title">Percorsi personalizzati</h2>
                </div>
                <div class="services-grid">
                    <a href="/servizi/percorso-radici" class="service-card">
                        <div class="service-image-wrapper">
                            <img
                                src="https://images.unsplash.com/photo-1547401372-0ac4589c4d3e?w=900&auto=format&fit=crop&q=60&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxzZWFyY2h8MXx8cm9vdHN8ZW58MHx8MHx8fDI%3D"
                                alt="Percorso Radici - Naturopatia"
                                class="service-img"
                            />
                        </div>
                        <h3 class="service-title">Percorso <br /> "Radici"</h3>
                        <p class="service-excerpt">
                            Un'analisi approfondita del tuo stato di benessere
                            per definire un piano personalizzato.
                        </p>
                        <span class="service-link">Dettagli →</span>
                    </a>
                    <a href="/servizi/incontro-la-prima-semina" class="service-card">
                        <div class="service-image-wrapper">
                            <img
                                src="https://images.unsplash.com/photo-1731119414875-799ff8cdbbdd?q=80&w=1742&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D"
                                alt="Incontro La prima semina - Floriterapia"
                                class="service-img"
                            />
                        </div>
                        <h3 class="service-title">
                            Incontro singolo <br />"La prima semina"
                        </h3>
                        <p class="service-excerpt">
                            Una sessione 1:1, se hai bisogno di fare chiarezza
                            su cosa vuoi davvero trasformare..
                        </p>
                        <span class="service-link">Dettagli →</span>
                    </a>
                </div>
            </div>
        </section>

        <!-- CONTATTI SECTION -->
        <section class="contact-section" id="contatti">
			<!-- SVG Divider between Services and Contact -->
			<WavyDivider position="top" color="var(--accent-1-bg)" />
            <div class="contact-container">
                <div class="contact-header">
                    <span class="section-overline">Contatti</span>
                    <h2 class="section-title">Iniziamo a camminare insieme</h2>
                    <p class="section-text">
                        Se senti che è arrivato il momento di rimettere radici in te stessa, scrivimi.
                        Sarò felice di ascoltare la tua storia e capire come posso accompagnarti nel tuo viaggio di benessere.
                    </p>
                </div>
                <form
                    name="contact"
                    method="POST"
                    data-netlify="true"
                    class="contact-form"
                >
                    <div class="form-group">
                        <label for="name">Nome e Cognome</label>
                        <input
                            type="text"
                            id="name"
                            name="name"
                            required
                            placeholder="Inserisci il tuo nome"
                        />
                    </div>
                    <div class="form-group">
                        <label for="email">Email</label>
                        <input
                            type="email"
                            id="email"
                            name="email"
                            required
                            placeholder="latua@email.it"
                        />
                    </div>
                    <div class="form-group">
                        <label for="reason">Di cosa hai bisogno?</label>
                        <select id="reason" name="reason" required>
                            <option value="" disabled selected>Seleziona un'opzione</option>
                            <option value="percorso-radici">Percorso "Radici" (Naturopatia)</option>
                            <option value="floriterapia">Incontro singolo (Floriterapia)</option>
                            <option value="chiamata-conoscitiva">Chiamata conoscitiva gratuita</option>
                            <option value="altro">Altro</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label for="message">Messaggio</label>
                        <textarea
                            id="message"
                            name="message"
                            rows="5"
                            required
                            placeholder="Come posso aiutarti?"></textarea>
                    </div>
                    <div class="form-group checkbox-group">
                        <label class="checkbox-container">
                            <input type="checkbox" name="privacy" required />
                            <span class="checkmark"></span>
                            <span class="privacy-text">
                                Accetto la <a href="/privacy">Privacy Policy</a> e il trattamento dei dati personali.
                            </span>
                        </label>
                    </div>
                    <button type="submit" class="btn-primary"
                        >Invia Messaggio</button
                    >
                </form>
            </div>
        </section>
    </main>
</BaseLayout>

<style>
    /* --- COMMON / RESET --- */
    .home-main {
        margin: 0 !important;
        padding: 0 !important;
        width: 100% !important;
        overflow-x: hidden;
    }

    section {
        padding: 5rem 1.5rem;
        position: relative;
    }

    /* --- HERO --- */
    .hero {
        position: relative;
        min-height: 100vh;
        width: 100%;
        overflow: hidden;
        display: flex;
        align-items: center;
        padding-bottom: 0;
    }

    .hero-bg {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        display: grid;
        grid-template-columns: 37% 63%;
        z-index: 1;
        padding-bottom: 0px;
    }

    .bg-left {
        background: url("/mare.webp");
        background-size: cover;
        background-position: center;
        animation: slideShow 15s infinite ease-in-out;
    }

    @keyframes slideShow {
        0%,
        30% {
            background-image: url("/mare.webp");
        }
        33%,
        63% {
            background-image: url("/monstera.webp");
        }
        66%,
        96% {
            background-image: url("/nuraghe.webp");
        }
        100% {
            background-image: url("/mare.webp");
        }
    }

    .bg-right {
        background-color: var(--accent-3);
    }

    .hero-container {
        position: relative;
        z-index: 2;
        width: 100%;
        height: 100%;
        display: grid;
        grid-template-columns: 38% 62%;
        padding: 60px 0px;
    }

    .col-img {
        display: flex;
        align-items: center;
        justify-content: flex-end;
    }

    .arch-wrapper {
        width: 55%;
        max-width: 500px;
        aspect-ratio: 0.65;
        border-radius: 300px 300px 5px 5px;
        overflow: hidden;
        transform: translateX(20%);
        border: solid 2px var(--brand-gold);
        box-shadow: 10px 10px 30px rgba(0, 0, 0, 0.35);
    }

    .hero-arch-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
    }

    .col-text {
        display: flex;
        align-items: center;
        padding-left: 10%;
        padding-right: 5%;
    }

    .text-content {
        max-width: 650px;
    }

    /* --- ABOUT --- */
    .about-section {
        background-color: var(--bg-light);
    }

    .about-container {
        max-width: var(--container-width);
        margin: 0 auto;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 6rem;
        align-items: center;
    }

    .about-arch-wrapper {
        width: 100%;
        max-width: 450px;
        aspect-ratio: 0.8;
        border-radius: 300px 300px 5px 5px;
        overflow: hidden;
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.1);
    }

    .about-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .about-text-col {
        max-width: 500px;
    }

    /* --- CTA BANNER --- */
    

    

    /* Gestione dei Divider come Maschere */
    .mask-top svg {
        height: 40px; /* Regola quanto deve essere profonda l'onda */
    }

    .mask-bottom svg {
        height: 60px;
        transform: scaleY(
            -1
        ); /* Inverte l'onda per "chiudere" verso il basso */
    }

    .fill-about {
        fill: var(--bg-light); /* Colore della sezione Chi Sono */
    }

    .fill-services {
        fill: var(--accent-1-bg); /* Colore della sezione Servizi */
    }

    

    

    

    /* --- SERVICES --- */
    .services-section {
        background-color: var(--accent-1-bg);
    }

    .services-container {
        max-width: var(--container-width);
        margin: 0 auto;
    }

    .services-header {
        text-align: center;
        margin-bottom: 4rem;
    }

    .services-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 2rem;
    }

    .service-card {
        background-color: white;
        padding: 2.5rem 2rem;
        border-radius: 12px;
        text-decoration: none;
        color: inherit;
        position: relative;
        transition: transform 0.4s cubic-bezier(0.165, 0.84, 0.44, 1),
            box-shadow 0.4s ease;
        display: flex;
        flex-direction: column;
        overflow: hidden;
        border: 1px solid rgba(0, 0, 0, 0.03);
    }

    .service-image-wrapper {
        position: relative;
        width: calc(100% + 4rem);
        margin: -2.5rem -2rem 2rem -2rem;
        aspect-ratio: 16/10;
        overflow: hidden;
    }

    .service-image-wrapper::after {
        content: "";
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background-color: rgba(0, 0, 0, 0.4);
        transition: background-color 0.4s ease;
        z-index: 1;
    }

    .service-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.8s cubic-bezier(0.165, 0.84, 0.44, 1);
    }

    .service-card:hover {
        transform: translateY(-10px);
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.05);
    }

    .service-card:hover .service-img {
        transform: scale(1.05);
    }

    .service-card:hover .service-image-wrapper::after {
        background-color: rgba(0, 0, 0, 0.1);
    }

    .service-title {
        z-index: 3;
        position: absolute;
        left: 2rem;
        margin: 0 !important;
        font-family: var(--font-headings);
        font-size: 2.2rem;
        color: var(--bg-light);
        text-shadow: 0 2px 10px rgba(0, 0, 0, 0.3);
    }

    .service-excerpt {
        font-family: var(--font-body);
        line-height: 1.6;
        margin-bottom: 2rem;
        flex-grow: 1;
    }

    .service-link {
        font-weight: 600;
        color: var(--brand-gold);
        text-transform: uppercase;
        font-size: 12px;
        letter-spacing: 1px;
    }

    /* --- CONTACT --- */
    .contact-section {
        background-color: var(--bg-light);
    }

    .contact-container {
        max-width: 700px;
        margin: 0 auto;
    }

    .contact-header {
        text-align: center;
        margin-bottom: 4rem;
    }

    .contact-form {
        display: grid;
        gap: 2rem;
    }

    .form-group {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    .form-group label {
        font-weight: 600;
        font-size: 14px;
        color: var(--brand-primary);
    }

    .form-group input,
    .form-group textarea {
        padding: 1rem;
        border: 1px solid rgba(0, 0, 0, 0.1);
        border-radius: 4px;
        font-family: var(--font-body);
        outline: none;
        transition: border-color 0.3s ease;
        background: var(--bg-lighter);
    }

    .form-group input:focus,
    .form-group textarea:focus {
        border-color: var(--brand-gold);
    }

    /* Stile specifico per il Select (Dropdown) */
    .form-group select {
        padding: 1rem;
        border: 1px solid rgba(0, 0, 0, 0.1);
        border-radius: 4px;
        font-family: var(--font-body);
        background-color: var(--bg-lighter);
        cursor: pointer;
        outline: none;
    }

    .form-group select:focus {
        border-color: var(--brand-gold);
    }

    /* Checkbox e Privacy */
    .checkbox-group {
        flex-direction: row;
        align-items: flex-start;
        gap: 1rem;
        margin-top: 1rem;
    }

    .checkbox-container {
        display: flex;
        gap: 0.8rem;
        cursor: pointer;
        font-size: 0.9rem;
        line-height: 1.4;
    }

    .checkbox-container input {
        width: 18px;
        height: 18px;
        margin-top: 2px;
        accent-color: var(--brand-primary);
    }

    .privacy-text a {
        color: var(--brand-primary);
        text-decoration: underline;
        font-weight: 600;
    }

    /* --- RESPONSIVE --- */
    @media (max-width: 1024px) {
        .hero {
            height: auto;
            min-height: 100vh;
            display: block;
        }

        .hero-bg {
            grid-template-columns: 1fr;
            grid-template-rows: 40% 60%;
        }

        .hero-container {
            grid-template-columns: 1fr;
            padding-bottom: 5rem;
        }

        .col-img {
            justify-content: center;
            height: 50vh;
        }

        .arch-wrapper {
            transform: translateX(0);
            width: 60%;
            margin: 0 auto;
        }

        .col-text {
            padding: 4rem 1.5rem 0;
            text-align: center;
            justify-content: center;
        }

        .about-container {
            grid-template-columns: 1fr;
            gap: 3rem;
            text-align: center;
        }

        .about-arch-wrapper {
            margin: 0 auto;
        }

        .about-text-col {
            margin: 0 auto;
        }

        .services-grid {
            grid-template-columns: 1fr;
        }

        .service-title {
            font-size: 1.8rem;
        }
    }
</style>
