---
import BaseLayout from "../layouts/BaseLayout.astro";
import WavyDivider from "../components/WavyDivider.astro";
const base = import.meta.env.BASE_URL;
---

<BaseLayout 
    title="Contatti | Marta Zola" 
    description="Inizia il tuo percorso di benessere. Scrivimi per informazioni o per prenotare una consulenza."
>
    <main class="contact-page">
        <section class="contact-hero">
            <div class="container container-narrow">
                <span class="section-overline">Contatti</span>
                <h1 class="hero-title">Possiamo iniziare da qui...</h1>
                <p class="hero-description">
                    Scegli la modalità più comoda per te: scrivimi un messaggio o prenota direttamente la tua call gratuita.
                </p>
            </div>
            <WavyDivider position="bottom" color="var(--bg-lighter)" />
        </section>

        <section class="contact-grid-section">
            <div class="container">
                <div class="contact-main-grid">
                    
                    <div class="form-col">
                        <div class="contact-card">
                            <h2 class="card-title">Inviami un messaggio</h2>
                            <p class="card-subtitle">Scrivimi attraverso questo form per richiedere informazioni o acquistare un servizio.</p>
                            
                            <form
                                name="contact"
                                method="POST"
                                data-netlify="true"
                                class="contact-form"
                            >
                                <div class="form-group">
                                    <label for="name">Nome e Cognome</label>
                                    <input
                                        type="text"
                                        id="name"
                                        name="name"
                                        required
                                        placeholder="Inserisci il tuo nome"
                                    />
                                </div>
                                <div class="form-group">
                                    <label for="email">Email</label>
                                    <input
                                        type="email"
                                        id="email"
                                        name="email"
                                        required
                                        placeholder="latua@email.it"
                                    />
                                </div>
                                <div class="form-group">
                                    <label for="reason">Di cosa hai bisogno?</label>
                                    <select id="reason" name="reason" required>
                                        <option value="" disabled selected>Seleziona un'opzione</option>
                                        <option value="percorso-radici">Percorso "Radici"</option>
                                        <option value="la-prima-semina">Incontro singolo "La prima semina"</option>
                                        <option value="chiamata-conoscitiva">Chiamata conoscitiva gratuita</option>
                                        <option value="altro">Altre informazioni</option>
                                    </select>
                                </div>
                                <div class="form-group">
                                    <label for="message">Messaggio</label>
                                    <textarea
                                        id="message"
                                        name="message"
                                        rows="5"
                                        required
                                        placeholder="Come posso aiutarti?"></textarea>
                                </div>
                                <div class="form-group checkbox-group">
                                    <label class="checkbox-container">
                                        <input type="checkbox" name="privacy" required />
                                        <span class="privacy-text">
                                            Accetto la <a href="/privacy">Privacy Policy</a> e il trattamento dei dati personali.
                                        </span>
                                    </label>
                                </div>
                                <button type="submit" class="btn-primary">Invia Messaggio</button>
                            </form>
                        </div>
                    </div>

                    <div class="calendar-col">
                        <div class="contact-card gold-border">
                            <h2 class="card-title">Prenota la tua Call</h2>
                            <p class="card-subtitle">Se vuoi prenotare il mio <strong>Spazio di Ascolto Conoscitivo</strong>, scegli data e ora qui sotto. Riceverai un link una volta confermato l'appuntamento. Vuoi saperne di più? <a href={ base + "/call-conoscitiva/"} class="text-link";>Clicca qui.</a></p>
                            
                            <div class="calendly-inline-widget" 
                                 data-url="https://calendly.com/TUO_LINK/30min" 
                                 style="min-width:320px; height:650px;">
                            </div>
                            <script type="text/javascript" src="https://assets.calendly.com/assets/external/widget.js" async></script>
                        </div>
                    </div>

                </div>
            </div>
        </section>
    </main>
</BaseLayout>

<style>
    .contact-page { background-color: var(--bg-lighter); }

    /* HERO */
    .contact-hero {
        background-color: var(--accent-1-bg);
        padding: 10rem 0 5rem;
        text-align: center;
        position: relative;
    }

    .hero-description {
        max-width: 700px;
        margin: 0 auto;
        line-height: 1.6;
    }
    .text-link {
        color: var(--brand-primary);
        text-decoration: none;
        border-bottom: 1px solid var(--brand-gold);
        transition: all 0.3s ease;
        padding-bottom: 1px;
    }

    .text-link:hover {
        color: var(--brand-gold);
        border-bottom-color: var(--brand-primary);
    }
    /* GRID LAYOUT */
    .contact-main-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 3rem;
        padding: 4rem 0 8rem;
        align-items: start;
    }

    .contact-card {
        background: white;
        padding: 2.5rem;
        border-radius: 15px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.03);
    }

    .gold-border { border: 1px solid var(--brand-gold); }

    .card-title {
        font-family: var(--font-headings);
        color: var(--brand-primary);
        margin-bottom: 0.5rem;
        font-size: 1.8rem;
    }

    .card-subtitle {
        font-size: 0.95rem;
        margin-bottom: 2rem;
        opacity: 0.9;
        line-height: 1.5;
    }

    /* FORM STYLING */
    .contact-form { display: flex; flex-direction: column; gap: 1.5rem; }

    .form-group { display: flex; flex-direction: column; gap: 0.5rem; }

    .form-group label {
        font-weight: 600;
        font-size: 14px;
        color: var(--brand-primary);
    }

    .form-group input, .form-group textarea, .form-group select {
        padding: 1rem;
        border: 1px solid rgba(0, 0, 0, 0.1);
        border-radius: 4px;
        font-family: var(--font-body);
        background-color: var(--bg-lighter);
        outline: none;
        transition: border-color 0.3s ease;
    }

    .form-group input:focus, .form-group textarea:focus, .form-group select:focus {
        border-color: var(--brand-gold);
    }

    /* Checkbox */
    .checkbox-group { margin-top: 0.5rem; }

    .checkbox-container {
        display: flex;
        gap: 0.8rem;
        cursor: pointer;
        font-size: 0.9rem;
        line-height: 1.4;
    }

    .privacy-text a {
        color: var(--brand-primary);
        text-decoration: underline;
        font-weight: 600;
    }

    /* RESPONSIVE */
    @media (max-width: 1024px) {
        .contact-main-grid {
            grid-template-columns: 1fr;
            gap: 2rem;
        }
        .contact-hero { padding: 8rem 1.5rem 4rem; }
    }
</style>