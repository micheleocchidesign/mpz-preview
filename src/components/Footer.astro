        height: 20px;
    }

    .footer-bottom {
        border-top: 1px solid rgba(255, 255, 255, 0.1);
        padding-top: 2rem;
        text-align: center;
        font-size: 0.9rem;
        opacity: 0.6;
    }

    .legal-disclaimer{
        font-size:12px;
    }

