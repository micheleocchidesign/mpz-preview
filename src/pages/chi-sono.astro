</style>
<script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    // Registriamo il plugin per Astro
    gsap.registerPlugin(ScrollTrigger);

    // Usiamo matchMedia per attivare l'effetto solo su schermi grandi
    let mm = gsap.matchMedia();

    mm.add("(min-width: 1024px)", () => {
        // Selezioniamo gli elementi
        const section = document.querySelector(".bio-extended-grid");
        const image = document.querySelector(".bio-portrait-large");

        if (section && image) {
            ScrollTrigger.create({
                trigger: section,
                start: "top 10%", // Quando l'inizio della sezione arriva al 15% della finestra
                end: "bottom 90%", // Si sgancia quando la fine della sezione raggiunge l'85%
                pin: image,       // L'elemento da bloccare
                pinSpacing: false, // Evita che GSAP crei spazi bianchi extra
                scrub: true,       // Rende il movimento fluido
                // markers: true,  // Togli il commento a questa riga per vedere i punti di inizio/fine durante i test
            });
        }
    });
</script>