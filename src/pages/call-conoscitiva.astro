---
import BaseLayout from "../layouts/BaseLayout.astro";
import WavyDivider from "../components/WavyDivider.astro";
import LunarPhases from "../components/LunarPhases.astro";
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Spazio di Ascolto Conoscitivo | Marta Zola">
    <main class="call-page">
        <section class="call-hero">
            <div class="container-narrow text-center">
                <span class="section-overline">Incontro Gratuito</span>
                <h1 class="hero-title">Spazio di ascolto conoscitivo gratuito di 30 minuti</h1>
                <p class="hero-description">Un incontro breve e protetto se senti che il corpo ti sta chiedendo di fermarti, ma non sai se un approccio olistico sia ciò che fa per te. Uno spazio di ascolto e chiarezza, senza impegno.</p>
            </div>
            <WavyDivider position="bottom" color="var(--bg-light)" />
        </section>

        <section class="call-content">
            <div class="container">
                <div class="content-grid">
                    <div class="text-col">
                        <div class="description">
                            <p>Questo è uno spazio pensato per chi è indecisa e desidera un primo momento di ascolto. Non è un incontro individuale come <strong><a href={base + "servizi/incontro-la-prima-semina"} class="text-link">"La prima semina"</a></strong>, né un percorso più lungo come <strong><a href={base + "servizi/percorso-radici"} class="text-link">"Radici"</a></strong>, ma un incontro per fare chiarezza.</p>
                            
                            <p>Alla fine dell’incontro puoi semplicemente ascoltare come ti sei sentita, prenderti il tuo tempo e scegliere solo se e quando sarà il momento giusto per te.</p>
                        </div>
                    </div>

                    <div class="side-col">
                        <div class="calendar-card">
                            <h3 class="card-title-small">Scegli il tuo momento</h3>
                            <p>Cliccando il tasto qui sotto verrai indirizzata alla pagina di prenotazione dove potrai scegliere il giorno e l'ora che preferisci.</p>
                            
                            <a href="https://calendly.com/martazola-info/30min" target="_blank" rel="noopener noreferrer" class="btn-primary">
                                Prenota ora
                            </a>
                            <p class="small-note">Il link si aprirà in una nuova scheda</p>
                        </div>
                    </div>
                </div>

                <div class="newsletter-full-width">
                    <div class="newsletter-inner">
                        <div class="newsletter-text">
                            <h3>Rimani in contatto</h3>
                            <p>Se ti va di iniziare a conoscermi un po’ di più anche in altre forme, iscriviti a <strong>"Semi"</strong>, la newsletter con consigli, riflessioni e pillole di Naturopatia.</p>
                        </div>
                        <div class="newsletter-action">
                            <a href={base + "newsletter"} class="btn-primary">
                                <span>Iscriviti a "Semi"</span>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </main>
</BaseLayout>

<style>
    .call-page { background-color: var(--bg-light); padding-bottom: 5rem; }

    /* Hero */
    .call-hero {
        background-color: var(--accent-3);
        padding: 8rem 1.5rem 4rem;
        position: relative;
    }

    /* Grid Superiore */
    .content-grid {
        display: grid;
        grid-template-columns: 1.2fr 0.8fr;
        gap: 5rem;
        padding: 4rem 0;
        align-items: center;
    }

    .description p {
        margin-bottom: 1.5rem;
        font-size: 1.15rem;
        line-height: 1.8;
    }

    /* Card Calendly a destra */
    .calendar-card {
        background: white;
        padding: 2.5rem;
        border-radius: 15px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.03);
        border: 1px solid var(--brand-gold);
        text-align: center;
    }

    /* Blocco Newsletter Orizzontale */
    .newsletter-full-width {
        margin-top: 4rem;
        padding: 3rem;
        background-color: var(--accent-1-bg); /* O var(--bt-light) se preferisci */
        border-radius: 20px;
    }

    .newsletter-inner {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 3rem;
    }

    .newsletter-text h3 {
        font-family: var(--font-headings);
        color: var(--brand-primary);
        font-size: 1.8rem;
        margin-bottom: 0.5rem;
    }

    .newsletter-action {
        flex-shrink: 0;
    }

    /* Utility */
    .card-title-small { font-family: var(--font-headings); color: var(--brand-primary); font-size: 1.6rem; margin-bottom: 1rem; }
    .text-link { color: var(--brand-primary); text-decoration: none; border-bottom: 1px solid var(--brand-gold); }
    .small-note { font-size: 0.8rem; margin-top: 1rem; opacity: 0.6; }

    .btn-newsletter-inline {
        display: inline-flex;
        align-items: center;
        gap: 0.8rem;
        background-color: var(--brand-primary);
        color: white;
        padding: 1rem 2rem;
        text-decoration: none;
        border-radius: 4px;
        font-family: var(--font-headings);
        font-weight: 600;
        transition: all 0.3s ease;
    }

    .btn-newsletter-inline:hover { background-color: var(--brand-gold); }

    /* Responsive */
    @media (max-width: 1024px) {
        .content-grid { grid-template-columns: 1fr; gap: 3rem; }
        .newsletter-inner { flex-direction: column; text-align: center; gap: 2rem; }
        .newsletter-action { width: 100%; }
        .btn-newsletter-inline { width: 100%; justify-content: center; }
    }
</style>