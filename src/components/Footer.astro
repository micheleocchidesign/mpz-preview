        font-family: var(--font-body);
    }

    .footer-container {
        max-width: var(--container-width);
        margin: 0 auto;
    }

    .footer-grid {
        display: grid;
        grid-template-columns: 4fr 3fr 1fr 2fr; /* Proporzioni bilanciate */
        gap: 3rem;
        margin-bottom: 4rem;
    }

    .footer-logo-link {
        display: inline-block;
    }

    .footer-logo-img {
        height: 45px; /* Regola l'altezza desiderata */
        width: auto;
        display: block;
    }

    .footer-tagline {
