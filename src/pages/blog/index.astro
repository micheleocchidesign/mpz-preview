---
import BaseLayout from "../../layouts/BaseLayout.astro";
import WavyDivider from "../../components/WavyDivider.astro";
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';

const base = import.meta.env.BASE_URL;

// Recuperiamo tutti gli articoli del blog che non sono contrassegnati come bozza (draft)
// e li ordiniamo dal più recente al più vecchio
const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title="Blog - Spazi di Riflessione | Marta Zola">
    <main>
        <section class="blog-hero">
            <div class="container container-narrow text-center">
                <span class="section-overline">Spazi di riflessione</span>
                <h1 class="hero-title">Il mio Blog</h1>
                <p class="hero-description">
                    Pensieri, approfondimenti e pratiche sulla naturopatia integrata, il benessere femminile, la riflessologia e l'ascolto profondo dei ritmi del corpo.
                </p>
            </div>
            <WavyDivider position="bottom" color="var(--accent-1-bg)" />
        </section>

        <section class="blog-list-section">
            <div class="container">
                {posts.length === 0 ? (
                    // Messaggio se non ci sono ancora articoli pubblicati
                    <div class="no-posts text-center">
                        <p>Al momento non ci sono articoli. Torna presto a trovarmi!</p>
                    </div>
                ) : (
                    // Griglia degli articoli
                    <div class="blog-grid">
                        {posts.map(post => (
                            <article class="blog-card">
                                <div class="card-image-wrapper">
                                    <Image 
                                        src={post.data.heroImage} 
                                        alt={post.data.title}
                                        class="card-img"
                                        format="webp"
                                        width={600}
                                        height={400}
                                    />
                                    <span class="card-category">{post.data.category}</span>
                                </div>
                                <div class="card-content">
                                    <time class="card-date">
                                        {post.data.pubDate.toLocaleDateString('it-IT', {
                                            year: 'numeric',
                                            month: 'long',
                                            day: 'numeric'
                                        })}
                                    </time>
                                    <h2 class="card-title">{post.data.title}</h2>
                                    <p class="card-excerpt">{post.data.description}</p>
                                    <a href={base + `blog/${post.id}`} class="btn-link">
                                        Leggi l'articolo <span class="arrow">→</span>
                                    </a>
                                </div>
                            </article>
                        ))}
                    </div>
                )}
            </div>
        </section>
    </main>
</BaseLayout>

<style>
    section { padding: 5rem 1.5rem; }

    /* Hero */
    .blog-hero {
        background-color: var(--bg-light);
        position: relative;
        padding: 10rem 0 3rem;
    }

    /* Griglia Blog */
    .blog-list-section {
        background-color: var(--accent-1-bg);
    }

    .blog-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
        gap: 3rem;
        max-width: var(--container-width);
        margin: 0 auto;
    }

    /* Card Singola */
    .blog-card {
        background: white;
        border-radius: 8px;
        overflow: hidden;
        box-shadow: 0 10px 30px rgba(0,0,0,0.03);
        border: 1px solid rgba(0,0,0,0.03);
        display: flex;
        flex-direction: column;
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

    .blog-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 15px 35px rgba(0,0,0,0.08);
    }

    .card-image-wrapper {
        position: relative;
        width: 100%;
        aspect-ratio: 1.5;
        overflow: hidden;
    }

    .card-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .card-category {
        position: absolute;
        bottom: 15px;
        left: 15px;
        background: var(--brand-primary);
        color: white;
        padding: 0.4rem 1rem;
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        font-weight: 600;
        border-radius: 4px;
    }

    .card-content {
        padding: 2rem;
        display: flex;
        flex-direction: column;
        flex-grow: 1;
    }

    .card-date {
        font-size: 0.85rem;
        color: var(--brand-gold);
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-bottom: 0.5rem;
        font-weight: 500;
    }

    .card-title {
        font-size: 1.6rem;
        color: var(--brand-primary);
        margin: 0 0 1rem 0;
        line-height: 1.3;
    }

    .card-excerpt {
        font-size: 0.95rem;
        color: var(--text-dark);
        line-height: 1.6;
        margin: 0 0 2rem 0;
        flex-grow: 1; /* Spinge il pulsante sempre in fondo */
    }

    .btn-link {
        color: var(--brand-primary);
        font-weight: bold;
        text-decoration: none;
        font-size: 0.95rem;
        display: inline-flex;
        align-items: center;
        gap: 5px;
        transition: color 0.3s ease;
    }

    .btn-link:hover {
        color: var(--brand-gold);
    }

    .btn-link .arrow {
        transition: transform 0.3s ease;
    }

    .btn-link:hover .arrow {
        transform: translateX(5px);
    }

    .no-posts {
        padding: 4rem 0;
        font-family: var(--font-headings);
        font-size: 1.2rem;
        color: var(--brand-primary);
    }

    @media (max-width: 480px) {
        .blog-grid {
            grid-template-columns: 1fr;
        }
    }
</style>