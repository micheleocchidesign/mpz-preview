---
import BaseLayout from "../layouts/BaseLayout.astro";
import WavyDivider from "../components/WavyDivider.astro";
import LunarPhases from "../components/LunarPhases.astro";
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Spazio di Ascolto Conoscitivo | Marta Zola">
    <main class="call-page">
        <section class="call-hero">
            <div class="container-narrow text-center">
                <span class="section-overline">Incontro Gratuito</span>
                <h1 class="hero-title">Spazio di ascolto conoscitivo gratuito di 30 minuti</h1>
                <p class="hero-description">Un incontro breve e protetto se senti che il corpo ti sta chiedendo di fermarti, ma non sai se un approccio olistico sia ciò che fa per te. Uno spazio di ascolto e chiarezza, senza impegno.</p>
            </div>
            <WavyDivider position="bottom" color="var(--bg-light)" />
        </section>

        <section class="call-content">
            <div class="container">
                <div class="content-grid">
                    <div class="text-col">
                        <div class="description">
                            <p>Questo è uno spazio pensato per chi è indecisa e desidera un primo momento di ascolto. Non è un incontro individuale come <strong><a href={base + "/servizi/incontro-la-prima-semina"} class="text-link">"La prima semina"</a></strong>, né un percorso più lungo come <strong><a href={base + "/servizi/percorso-radici"} class="text-link">"Radici"</a></strong>, ma un incontro per fare chiarezza.</p>
                            
                            <p>Alla fine dell’incontro puoi semplicemente ascoltare come ti sei sentita, prenderti il tuo tempo e scegliere solo se e quando sarà il momento giusto per te.</p>
                        </div>

                        <div class="newsletter-box">
                            <p>Se ti va di iniziare a conoscermi un po’ di più anche in altre forme, 
                            iscriviti a <strong>"Semi"</strong>, la newsletter con consigli, riflessioni e pillole di Naturopatia.</p>
                            
                            <div class="newsletter-cta-wrapper">
                                <a href={base + "/newsletter"} class="btn-newsletter-inline">
                                    <span>Voglio iscrivermi a "Semi"</span>
                                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
                                </a>
                            </div>
                        </div>
                    </div>

                    <div class="calendar-col">
                        <div class="calendar-card">
                            <h3 class="calendar-title">Scegli il tuo momento</h3>
                            <div class="calendly-placeholder">
                                <p>Qui apparirà il calendario di Calendly</p>
                                </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </main>
</BaseLayout>

<style>
    .call-page { background-color: var(--bg-light); }

    /* Hero */
    .call-hero {
        background-color: var(--accent-3);
        padding: 8rem 1.5rem 4rem;
        position: relative;
    }

    /* Grid */
    .content-grid {
        display: grid;
        grid-template-columns: 1.2fr 1fr; /* 1.2 parti al testo, 1 parte al calendario */
        gap: 5rem;
        padding: 4rem 0;
        align-items: start;
    }

    .highlight-text {
        font-family: var(--font-headings);
        font-size: 1.6rem;
        line-height: 1.4;
        color: var(--brand-primary);
        margin-bottom: 2rem;
    }

    .description p {
        margin-bottom: 1.5rem;
        font-size: 1.1rem;
        line-height: 1.7;
    }

    .text-link {
        color: var(--brand-primary);
        text-decoration: none;
        border-bottom: 1px solid var(--brand-gold);
        transition: all 0.3s ease;
        padding-bottom: 1px;
    }

    .text-link:hover {
        color: var(--brand-gold);
        border-bottom-color: var(--brand-primary);
    }

    /* Newsletter Box aggiornata */
.newsletter-box {
    margin-top: 3rem;
    padding: 2.5rem;
    background-color: var(--bt-light); /* Un tono leggermente diverso per staccare dal fondo */
    border-radius: 12px;
    border: 1px solid var(--brand-gold);
    box-shadow: 0 4px 15px rgba(0,0,0,0.02);
}

.newsletter-box p {
    margin-bottom: 1.5rem;
    font-size: 1.05rem;
    color: var(--brand-primary);
}

.newsletter-cta-wrapper {
    display: flex;
    justify-content: flex-start;
}

.btn-newsletter-inline {
    display: inline-flex;
    align-items: center;
    gap: 0.8rem;
    background-color: var(--brand-primary);
    color: white;
    padding: 1rem 1.8rem;
    text-decoration: none;
    border-radius: 4px;
    font-family: var(--font-headings);
    font-weight: 600;
    font-size: 1rem;
    transition: all 0.3s ease;
}

.btn-newsletter-inline:hover {
    background-color: var(--brand-gold);
    transform: translateY(-2px);
    box-shadow: 0 5px 15px rgba(0,0,0,0.1);
}

.btn-newsletter-inline svg {
    transition: transform 0.3s ease;
}

.btn-newsletter-inline:hover svg {
    transform: translateX(5px);
}

    /* Calendario */
    .calendar-card {
        background: white;
        padding: 2rem;
        border-radius: 15px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.05);
        border: 1px solid var(--brand-gold);
    }
    .calendar-title {
        text-align: center;
        margin-bottom: 1.5rem;
        font-family: var(--font-headings);
    }
    .calendly-placeholder {
        background: #f9f9f9;
        height: 500px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 8px;
    }

    @media (max-width: 1024px) {
        .content-grid { grid-template-columns: 1fr; gap: 3rem; }
        .text-col { order: 2; }
        .calendar-col { order: 1; }
        .newsletter-box {
        padding: 1.5rem;
        text-align: center;
    }
    .newsletter-cta-wrapper {
        justify-content: center;
    }
    .btn-newsletter-inline {
        width: 100%;
        justify-content: center;
    }
    }
</style>