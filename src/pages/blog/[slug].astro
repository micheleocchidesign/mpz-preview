---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import WavyDivider from '../../components/WavyDivider.astro';

const base = import.meta.env.BASE_URL;

// 1. Genera i percorsi (URL) per tutti gli articoli presenti nella cartella content
export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

// 2. Recupera i dati dell'articolo corrente
const { post } = Astro.props;
const { Content } = await post.render();
const pageTitle = `${post.data.title} | Marta Zola`;
---

<BaseLayout 
  title={pageTitle} 
>
  <main>
    <header class="post-header">
      <div class="container container-narrow text-center">
        <span class="post-category">{post.data.category}</span>
        <h1 class="post-title">{post.data.title}</h1>
        <div class="post-meta">
          <time datetime={post.data.pubDate.toISOString()}>
            {post.data.pubDate.toLocaleDateString('it-IT', {
              year: 'numeric',
              month: 'long',
              day: 'numeric'
            })}
          </time>
        </div>
      </div>
      <WavyDivider position="bottom" color="var(--bg-light)" />
    </header>

    <section class="post-content-section">
      <div class="container container-narrow">
        
        <div class="post-hero-image-wrapper">
          <img src={post.data.heroImage.src} alt={post.data.title} class="post-hero-img" />
        </div>

        <article class="post-body">
          <Content />
        </article>

        <div class="post-footer text-center">
          <hr class="footer-divider" />
          <a href={base + "blog"} class="btn-secondary">← Torna a tutti gli articoli</a>
        </div>

      </div>
    </section>
  </main>
</BaseLayout>

<style>
  /* Header */
  .post-header {
    background-color: var(--accent-1-bg);
    padding: 10rem 0 4rem;
    position: relative;
  }
  
  .post-category {
    text-transform: uppercase;
    font-size: 0.85rem;
    letter-spacing: 1.5px;
    color: var(--brand-gold);
    font-weight: bold;
    display: inline-block;
    margin-bottom: 1rem;
  }

  .post-title {
    font-size: 3rem;
    color: var(--brand-primary);
    line-height: 1.2;
    margin-bottom: 1.5rem;
  }

  .post-meta {
    font-size: 0.95rem;
    color: var(--text-dark);
    opacity: 0.8;
  }

  /* Sezione Contenuto */
  .post-content-section {
    background-color: var(--bg-light);
    padding: 4rem 1.5rem 8rem;
  }

  /* Copertina */
  .post-hero-image-wrapper {
    width: 100%;
    aspect-ratio: 16/9;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 20px 40px rgba(0,0,0,0.06);
    margin-bottom: 4rem;
  }

  .post-hero-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* STILIZZAZIONE DEL TESTO (Leggibilità dell'articolo) */
  .post-body {
    font-size: 1.15rem;
    line-height: 1.8;
    color: var(--text-dark);
  }

  /* Titoli intermedi (## e ### del CMS) */
  .post-body :global(h2) {
    font-size: 2rem;
    color: var(--brand-primary);
    margin: 3.5rem 0 1.5rem;
    line-height: 1.3;
  }

  .post-body :global(h3) {
    font-size: 1.5rem;
    color: var(--brand-primary);
    margin: 2.5rem 0 1rem;
  }

  /* Paragrafi ed elenchi */
  .post-body :global(p) {
    margin-bottom: 1.8rem;
  }

  .post-body :global(ul), .post-body :global(ol) {
    margin: 1.5rem 0 2rem 1.5rem;
  }

  .post-body :global(li) {
    margin-bottom: 0.6rem;
  }

  /* Citazioni (In evidenza nel testo) */
  .post-body :global(blockquote) {
    border-left: 4px solid var(--brand-gold);
    padding-left: 1.5rem;
    margin: 2.5rem 0;
    font-style: italic;
    color: var(--brand-primary);
    font-size: 1.25rem;
  }

  /* IMMAGINI INTERVALLATE NEL TESTO (Gestione automatica del CMS) */
  .post-body :global(img) {
    max-width: 100%;
    height: auto;
    border-radius: 8px;
    margin: 3rem auto;
    display: block;
    box-shadow: 0 10px 25px rgba(0,0,0,0.04);
  }

  /* Footer Articolo */
  .footer-divider {
    border: none;
    border-top: 1px solid rgba(0,0,0,0.08);
    margin: 5rem 0 3rem;
  }

  .btn-secondary {
    display: inline-block;
    padding: 0.8rem 2rem;
    border: 1px solid var(--brand-primary);
    color: var(--brand-primary);
    text-decoration: none;
    border-radius: 4px;
    font-weight: 600;
    transition: all 0.3s ease;
  }

  .btn-secondary:hover {
    background-color: var(--brand-primary);
    color: white;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .post-title { font-size: 2.2rem; }
    .post-body { font-size: 1.05rem; }
    .post-body :global(h2) { font-size: 1.6rem; }
  }
</style>